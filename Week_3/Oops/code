
import java.util.Random;

abstract class Compartment {
    public abstract String notice();
}

class FirstClass extends Compartment {
    public String notice() {
        return "Welcome to First Class. Enjoy a comfortable and premium journey.";
    }
}

class Ladies extends Compartment {
    public String notice() {
        return "This coach is reserved for women passengers only.";
    }
}

class General extends Compartment {
    public String notice() {
        return "General coach available for all passengers.";
    }
}

class Luggage extends Compartment {
    public String notice() {
        return "Luggage coach. Keep all goods and parcels here.";
    }
}

public class TestCompartment {

    public static void main(String[] args) {

        Compartment[] coach = new Compartment[10];
        Random r = new Random();

        for (int i = 0; i < coach.length; i++) {

            int type = r.nextInt(4) + 1;

            if (type == 1)
                coach[i] = new FirstClass();
            else if (type == 2)
                coach[i] = new Ladies();
            else if (type == 3)
                coach[i] = new General();
            else
                coach[i] = new Luggage();
        }

        System.out.println("Displaying notices for all compartments:\n");
        for (int i = 0; i < coach.length; i++) {
            System.out.println("Coach " + (i + 1) + " : " + coach[i].notice());
        }
    }
}
