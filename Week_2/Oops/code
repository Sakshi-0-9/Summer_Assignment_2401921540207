package music.wind;

import music.Playable;

public class Saxophone implements Playable {

    private String instrumentName;

    public Saxophone() {
        instrumentName = "Saxophone";
    }

    @Override
    public void play() {
        System.out.println(instrumentName + " is being played. Producing smooth jazz-like sounds.");
    }
}


package live;

import music.Playable;
import music.string.Veena;
import music.wind.Saxophone;

public class Test {

    public static void main(String[] args) {

        System.out.println("----- Direct Object Calls -----");

        Veena classicalInstrument = new Veena();
        classicalInstrument.play();

        Saxophone windInstrument = new Saxophone();
        windInstrument.play();

        System.out.println("\n----- Interface Reference Calls -----");
        Playable performer;
        performer = classicalInstrument;
        performer.play();
        performer = windInstrument;
        performer.play();
    }
}

