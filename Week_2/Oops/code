Playable.java
package music;

public interface Playable {
    void play();
}

----Veena.java
package music.string;

import music.Playable;

public class Veena implements Playable {

    private String instrumentName;

    public Veena() {
        instrumentName = "Veena";
    }

    @Override
    public void play() {
        System.out.println(instrumentName + " is being played. Producing pleasant classical notes.");
    }
}


