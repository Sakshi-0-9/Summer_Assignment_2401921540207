3-MAXIMUM AVERAGE SUBARRAY 1
  class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int max_sum=0;
        int current_sum=0;
        for(int i=0;i<k;i++){
            current_sum+=nums[i];
        }
        max_sum=current_sum;
        for(int i=k;i<nums.length;i++){
            current_sum=current_sum+nums[i]-nums[i-k];
            if(current_sum>max_sum){
                max_sum=current_sum;
            }
        }
        return(double)max_sum/k;
    }
}
